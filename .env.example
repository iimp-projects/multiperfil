# -----------------------------------------------------------------------------
# ARCHIVO DE CONFIGURACIÓN DE ENTORNO - IIMP MULTIPERFIL V2
# -----------------------------------------------------------------------------
# Este archivo fue recreado basándose en la arquitectura del proyecto.
# NOTA: No subir este archivo al repositorio (ya está en .gitignore).

# 1. BASE DE DATOS (MongoDB)
# Prisma requiere que MongoDB esté en modo "Replica Set" para habilitar transacciones.
# Requerido por: UserSessionLock (Session Control)
DATABASE_URL="mongodb://localhost:27017/multiperfil?replicaSet=rs0&directConnection=true"

# 2. API EXTERNA (Genexus)
# Configuración para validar credenciales y obtener datos de asociados.
NEXT_PUBLIC_API_DOMAIN="https://secure2.iimp.org:8443"
NEXT_PUBLIC_API_BASE_PATH="/KBServiciosPruebaIIMPJavaEnvironment/rest"
NEXT_PUBLIC_API_KEY="iimp-multiperfil-secret-2024"

# 3. CORREO ELECTRÓNICO (SMTP)
# Configuración para el envío de notificaciones y cupones.
SMTP_HOST="smtp-relay.sendinblue.com"
SMTP_PORT=587
SMTP_USER="postmast@iimp.org.pe"
SMTP_PASS="multiperfil2026"
SMTP_FROM='"IIMP - Eventos" <postmast@iimp.org.pe>'

# 4. MISCELÁNEOS
NEXT_PUBLIC_APP_VERSION="V1-Local"
NODE_ENV="development"
