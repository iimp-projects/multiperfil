generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model UserSession {
  id         String   @id @map("_id")
  userKey    String
  event      String
  docType    String
  document   String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  endedAt    DateTime?

  userAgent  String?
  ip         String?

  @@index([userKey])
  @@index([event, docType, document])
}

model UserSessionLock {
  userKey         String   @id @map("_id")
  activeSessionId String
  updatedAt       DateTime @updatedAt
}

model AdminUser {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  passwordHash   String
  name           String
  role           String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PortalMessage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  event        String
  senderName   String
  senderRole   String
  subject      String
  content      String
  preview      String
  createdAt    DateTime @default(now())
  recipients   String[] // Array de userKeys o vacío para todos
  readBy       String[] // Array de userKeys que ya leyeron
  archivedBy   String[] @default([]) // Array de userKeys que lo archivaron
  deletedBy    String[] @default([]) // Array de userKeys que lo eliminaron
}

model PortalAlert {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  event        String
  type         String   // NotificationType (standard, expandable, etc)
  variant      String?  // NotificationVariant (success, info, etc)
  category     String   // NotificationCategory (eventos, sistema, etc)
  title        String
  description  String?
  longDescription String?
  actionText   String?
  actionUrl    String?
  target       String?  // _blank or _self
  imageUrl     String?
  htmlContent  String?
  createdAt    DateTime @default(now())
  recipients   String[] // Array de userKeys
  readBy       String[] // Array de userKeys
  archivedBy   String[] @default([]) // Array de userKeys que lo archivaron
  deletedBy    String[] @default([]) // Array de userKeys que lo eliminaron
}

model PortalStreaming {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  event        String
  title        String
  description  String?
  vimeoId      String?
  url          String?
  status       String   @default("active") // active, scheduled, inactive
  startsAt     DateTime?
  expiresAt    DateTime?
  isRecurring  Boolean  @default(false)
  recurrenceType String @default("none")
  recurrenceInterval Int @default(1)
  createdAt    DateTime @default(now())
  recipients   String[] // Array de userKeys o vacío para todos
}

model RecipientGroup {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String?
  event        String
  userKeys     String[] // Array de siecodes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  userEmail String?
  userName  String?
  action    String   // e.g., "CREATE_USER", "LOGIN", "DELETE_MESSAGE"
  module    String   // e.g., "ADMIN_USERS", "AUTH", "MESSAGES"
  details   String?  // Descripción textual de la acción
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model PortalProgram {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  coverImage      String?
  brochureUrl     String?
  primaryColor    String?  @default("#f37021")
  secondaryColor  String?  @default("#ffffff")
  tertiaryColor   String?  @default("#333333")
  event           String
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tabs            PortalProgramTab[]
}

model PortalProgramTab {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  label        String   // Button label: "DÍA 1"
  dateTitle    String?  // Header: "LUNES MONDAY"
  dateNumber   String?  // Header large number: "04"
  color        String?  // Custom tab color
  programId    String   @db.ObjectId
  program      PortalProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  sessions     PortalProgramSession[]
  order        Int      @default(0)
}

model PortalProgramSession {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tabId       String   @db.ObjectId
  tab         PortalProgramTab @relation(fields: [tabId], references: [id], onDelete: Cascade)
  timeRange   String?  // "08:30 - 09:00"
  title       String
  speaker     String?
  description String?
  location    String?
  isHeader    Boolean  @default(false)
  color       String?  // Hex color for special sessions
  order       Int      @default(0)
}

model PortalSponsor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  logoUrl   String
  category  String   // Reference to SponsorCategory.name
  url       String?
  event     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SponsorCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  event     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, event])
}
