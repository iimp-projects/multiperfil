generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model UserSession {
  id         String   @id @map("_id")
  userKey    String
  event      String
  docType    String
  document   String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  endedAt    DateTime?

  userAgent  String?
  ip         String?

  @@index([userKey])
  @@index([event, docType, document])
}

model UserSessionLock {
  userKey         String   @id @map("_id")
  activeSessionId String
  updatedAt       DateTime @updatedAt
}

model AdminUser {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  email          String   @unique
  passwordHash   String
  name           String
  role           String   @default("admin")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PortalMessage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  event        String
  senderName   String
  senderRole   String
  subject      String
  content      String
  preview      String
  createdAt    DateTime @default(now())
  recipients   String[] // Array de userKeys o vacío para todos
  readBy       String[] // Array de userKeys que ya leyeron
  archivedBy   String[] @default([]) // Array de userKeys que lo archivaron
  deletedBy    String[] @default([]) // Array de userKeys que lo eliminaron
}

model PortalAlert {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  event        String
  type         String   // NotificationType (standard, expandable, etc)
  variant      String?  // NotificationVariant (success, info, etc)
  category     String   // NotificationCategory (eventos, sistema, etc)
  title        String
  description  String?
  longDescription String?
  actionText   String?
  actionUrl    String?
  target       String?  // _blank or _self
  imageUrl     String?
  htmlContent  String?
  createdAt    DateTime @default(now())
  recipients   String[] // Array de userKeys
  readBy       String[] // Array de userKeys
  archivedBy   String[] @default([]) // Array de userKeys que lo archivaron
  deletedBy    String[] @default([]) // Array de userKeys que lo eliminaron
}

model PortalStreaming {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  event        String
  title        String
  description  String?
  vimeoId      String?
  url          String?
  status       String   @default("active") // active, scheduled, inactive
  startsAt     DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  recipients   String[] // Array de userKeys o vacío para todos
}

model RecipientGroup {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String?
  event        String
  userKeys     String[] // Array de siecodes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
